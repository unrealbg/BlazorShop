@page "/my-cart"
@inject StorefrontApiClient ApiClient
@inject IStorefrontClientAppUrlResolver ClientAppUrlResolver

<PageTitle>My Cart</PageTitle>

<HeadContent>
    <meta name="robots" content="noindex,nofollow" />
</HeadContent>

<section class="mx-auto max-w-7xl px-4 pb-12 pt-10 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-start">
        <div class="flex-1 space-y-4">
            <header class="rounded-3xl border border-neutral-200/70 bg-white/90 p-8 shadow-lg">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Storefront Cart</p>
                        <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-neutral-900">My Cart</h1>
                        <p class="mt-3 max-w-2xl text-base leading-7 text-neutral-700">Review the items you picked from the public storefront before you continue to checkout.</p>
                    </div>

                    <div class="inline-flex items-center rounded-full bg-blue-50 px-4 py-2 text-sm font-semibold text-blue-900 shadow-sm">
                        @ItemCount item@(ItemCount == 1 ? string.Empty : "s") in cart
                    </div>
                </div>
            </header>

            @foreach (var alert in Alerts)
            {
                <div class="rounded-2xl border px-4 py-3 text-sm leading-6 @(alert.Level == "error"
                        ? "border-rose-200 bg-rose-50 text-rose-900"
                        : "border-amber-200 bg-amber-50 text-amber-900")">
                    @alert.Message
                </div>
            }

            @if (Lines.Count == 0)
            {
                <div class="rounded-3xl border border-dashed border-neutral-300 bg-white/80 px-6 py-10 text-center shadow-sm">
                    <h2 class="text-2xl font-bold text-neutral-900">Your cart is empty</h2>
                    <p class="mx-auto mt-3 max-w-xl text-base leading-7 text-neutral-700">Add products from the storefront and they will appear here for review before checkout.</p>
                    <div class="mt-6 flex flex-wrap justify-center gap-3">
                        <a href="@StorefrontRoutes.NewReleases" class="inline-flex items-center rounded bg-neutral-900 px-4 py-2 font-semibold text-white hover:bg-neutral-800">Shop New Releases</a>
                        <a href="@StorefrontRoutes.TodaysDeals" class="inline-flex items-center rounded bg-amber-500 px-4 py-2 font-semibold text-white hover:bg-amber-600">See Today's Deals</a>
                    </div>
                </div>
            }
            else
            {
                <div class="space-y-4">
                    @foreach (var line in Lines)
                    {
                        <article class="rounded-3xl border border-neutral-200/70 bg-white/95 p-5 shadow-md">
                            <div class="flex flex-col gap-4 sm:flex-row">
                                <div class="flex h-24 w-24 shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-neutral-50 ring-1 ring-black/5">
                                    @if (!string.IsNullOrWhiteSpace(line.ImageUrl))
                                    {
                                        <img src="@line.ImageUrl" alt="@line.DisplayName" class="h-full w-full object-contain" />
                                    }
                                    else
                                    {
                                        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500">Item</span>
                                    }
                                </div>

                                <div class="min-w-0 flex-1">
                                    @if (!string.IsNullOrWhiteSpace(line.ProductUrl))
                                    {
                                        <a href="@line.ProductUrl" class="text-xl font-bold text-neutral-900 hover:text-neutral-700">@line.DisplayName</a>
                                    }
                                    else
                                    {
                                        <h2 class="text-xl font-bold text-neutral-900">@line.DisplayName</h2>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(line.SizeValue))
                                    {
                                        <p class="mt-1 text-sm font-medium uppercase tracking-[0.16em] text-neutral-500">Size @line.SizeValue</p>
                                    }

                                    @if (line.IsUnavailable)
                                    {
                                        <p class="mt-3 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-sm leading-6 text-amber-900">This item could not be refreshed from the catalog. Review it before you continue.</p>
                                    }

                                    <div class="mt-4 grid gap-4 lg:grid-cols-[minmax(0,1fr)_auto_auto] lg:items-end">
                                        <div class="grid gap-4 sm:grid-cols-3">
                                            <div>
                                                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Unit Price</p>
                                                <p class="mt-1 text-lg font-bold text-neutral-900">EUR @line.UnitPriceDisplay</p>
                                            </div>

                                            <label class="block">
                                                <span class="text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Quantity</span>
                                                <input type="number"
                                                       min="1"
                                                       step="1"
                                                       value="@line.Quantity"
                                                       data-storefront-cart-quantity
                                                       data-product-id="@line.ProductId"
                                                       data-variant-id="@line.VariantId"
                                                       data-product-name="@line.DisplayName"
                                                       data-size-value="@line.SizeValue"
                                                       class="mt-1 w-24 rounded-xl border border-neutral-300 bg-white px-3 py-2 text-sm font-semibold text-neutral-900 focus:border-neutral-500 focus:outline-none" />
                                            </label>

                                            <div>
                                                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-neutral-500">Line Total</p>
                                                <p class="mt-1 text-lg font-bold text-neutral-900">EUR @line.LineTotalDisplay</p>
                                            </div>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(line.ProductUrl))
                                        {
                                            <a href="@line.ProductUrl" class="inline-flex items-center justify-center rounded bg-neutral-900 px-4 py-2 text-sm font-semibold text-white hover:bg-neutral-800">View Product</a>
                                        }

                                        <button type="button"
                                                data-storefront-cart-remove
                                                data-product-id="@line.ProductId"
                                                data-variant-id="@line.VariantId"
                                                data-product-name="@line.DisplayName"
                                                data-size-value="@line.SizeValue"
                                                class="inline-flex items-center justify-center rounded bg-white px-4 py-2 text-sm font-semibold text-rose-700 ring-1 ring-rose-200 hover:bg-rose-50">
                                            Remove
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            }
        </div>

        <aside class="w-full lg:sticky lg:top-6 lg:max-w-sm">
            <div class="rounded-3xl border border-neutral-200/70 bg-white/95 p-6 shadow-lg">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Order Summary</p>
                <h2 class="mt-2 text-2xl font-extrabold tracking-tight text-neutral-900">Ready for checkout</h2>

                <dl class="mt-6 space-y-3 text-sm text-neutral-700">
                    <div class="flex items-center justify-between gap-3">
                        <dt>Items</dt>
                        <dd class="font-semibold text-neutral-900">@ItemCount</dd>
                    </div>
                    <div class="flex items-center justify-between gap-3">
                        <dt>Subtotal</dt>
                        <dd class="font-semibold text-neutral-900">EUR @GrandTotalDisplay</dd>
                    </div>
                    <div class="flex items-center justify-between gap-3 border-t border-neutral-200 pt-3 text-base">
                        <dt class="font-semibold text-neutral-900">Total</dt>
                        <dd class="font-black text-neutral-900">EUR @GrandTotalDisplay</dd>
                    </div>
                </dl>

                <div class="mt-6 space-y-3">
                    @if (Lines.Count > 0)
                    {
                        <a href="@CheckoutUrl" class="inline-flex w-full items-center justify-center rounded bg-amber-500 px-4 py-3 font-semibold text-white hover:bg-amber-600">Continue to Checkout</a>
                        <p class="text-sm leading-6 text-neutral-600">Checkout continues through an authenticated handoff so payment and order history stay attached to your profile.</p>

                        <button type="button" data-storefront-cart-clear class="inline-flex w-full items-center justify-center rounded bg-white px-4 py-3 font-semibold text-neutral-900 ring-1 ring-black/10 hover:bg-neutral-100">Clear Cart</button>
                    }

                    <a href="@StorefrontRoutes.NewReleases" class="inline-flex w-full items-center justify-center rounded bg-neutral-900 px-4 py-3 font-semibold text-white hover:bg-neutral-800">Keep Shopping</a>
                </div>
            </div>
        </aside>
    </div>
</section>