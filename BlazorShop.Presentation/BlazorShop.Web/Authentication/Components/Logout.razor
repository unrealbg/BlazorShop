@page "/authentication/logout"
@inject BlazorShop.Web.Authentication.Providers.IAuthenticationStateNotifier AuthenticationStateNotifier

@code {

    protected override async Task OnInitializedAsync()
    {
        var response = await AuthenticationService.Logout();
        await TokenService.RemoveJwtTokenAsync(Constant.TokenStorage.Key);
        AuthenticationStateNotifier.NotifyAuthenticationState();

        if (response.Success)
        {
            var message = string.IsNullOrWhiteSpace(response.Message)
                ? "You have been signed out successfully."
                : response.Message;

            NotificationService.NotifySuccess(message, "Signed out", NotificationKind.Authentication, link: "/authentication/login/account");
        }
        else
        {
            NotificationService.NotifyWarning(
                "You were signed out locally, but we could not confirm the server logout request.",
                "Logout",
                NotificationKind.Authentication,
                link: "/authentication/login/account");
        }

        NavigationManager.NavigateTo("/authentication/login/account");
    }
}
