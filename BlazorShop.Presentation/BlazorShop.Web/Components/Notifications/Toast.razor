@using BlazorShop.Web.Shared.Toast
@if (_toasts.Any(t => t.Position == ToastPosition.TopRight))
{
    <div class="bs-toast-stack top-right">
        @foreach (var toast in _toasts.Where(t => t.Position == ToastPosition.TopRight))
        {
            <div class="bs-toast-card @toast.ToastLevel">
                <div class="bs-toast-header">
                    <div class="bs-toast-accent">
                        <i class="@GetToastIcon(toast)"></i>
                    </div>
                    <div class="min-w-0 flex-1">
                        <div class="bs-toast-heading-row">
                            <strong>@toast.Heading</strong>
                            <small>Just now</small>
                        </div>
                        <div class="bs-toast-body">
                            @((MarkupString)toast.Message)
                        </div>
                    </div>
                    <button type="button" class="bs-toast-close" @onclick="() => RemoveToast(toast)">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            </div>
        }
    </div>
}

