@page "/authentication/login"
@page "/authentication/login/{*route}"

<section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_20rem]">
    <div class="bs-panel overflow-hidden">
      <div class="border-b border-slate-200 px-6 py-6 sm:px-8">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">Account</p>
            <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950">Sign in</h1>
            <p class="mt-3 text-sm leading-6 text-slate-600">Open orders, notifications, settings, and checkout continuation.</p>
          </div>

          <a href="/authentication/register" class="bs-button bs-button-secondary">Create account</a>
        </div>
      </div>

      <div class="px-6 py-6 sm:px-8">
        @if (!string.IsNullOrEmpty(_message))
        {
          <div class="mb-4 rounded-2xl px-4 py-3 text-sm font-medium @( _alertType == "danger" ? "bg-red-50 text-red-700" : "bg-emerald-50 text-emerald-700")" role="alert">
            @_message
          </div>
        }

        <EditForm Model="User" OnValidSubmit="LoginUser">
          <DataAnnotationsValidator />
          <ValidationSummary class="mb-4 text-sm text-red-700" />
          <div class="mb-4">
            <ValidationMessage For="@(() => User.Email)" />
            <FloatingTextInput class="w-full border rounded px-3 py-2" @bind-Value="User.Email" Label="Email Address" Type="text" Placeholder="my@email.com" />
          </div>

          <div class="mb-6">
            <ValidationMessage For="@(() => User.Password)" />
            <FloatingTextInput class="w-full border rounded px-3 py-2" @bind-Value="User.Password" Label="Password" Type="Password" Placeholder="Password" />
          </div>

          <button type="submit" class="bs-button bs-button-primary w-full disabled:opacity-60 disabled:cursor-not-allowed" disabled="@IsSubmitting">@(IsSubmitting ? "Signing in..." : "Login")</button>
        </EditForm>
      </div>

      <div class="border-t border-slate-200 px-6 py-5 sm:px-8">
        <div class="flex flex-wrap items-center justify-between gap-3 text-sm text-slate-600">
          <span>Don't have an account yet?</span>
          <div class="bs-shell-inline-links">
            <a href="/authentication/register">Register</a>
            <a href="/">Access home</a>
          </div>
        </div>
      </div>
    </div>

    <aside class="space-y-4">
      <div class="bs-panel-soft p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">After sign-in</p>
        <div class="mt-4 space-y-3">
          <div class="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3 text-sm">
            <div class="font-semibold text-slate-950">Account dashboard</div>
            <div class="mt-1 text-slate-600">Profile summary, unread notifications, and shortcuts.</div>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3 text-sm">
            <div class="font-semibold text-slate-950">Orders and checkout</div>
            <div class="mt-1 text-slate-600">History, shipment state, and authenticated checkout continuation.</div>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3 text-sm">
            <div class="font-semibold text-slate-950">Admin tools</div>
            <div class="mt-1 text-slate-600">Available automatically when your role includes admin access.</div>
          </div>
        </div>
      </div>

      <div class="bs-panel-soft p-5">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Quick links</p>
        <div class="mt-4 flex flex-col gap-3 text-sm font-semibold">
          <a href="/authentication/register" class="bs-button bs-button-primary">Create account</a>
          <a href="/" class="bs-button bs-button-ghost">Access home</a>
        </div>
      </div>
    </aside>
  </div>
</section>

