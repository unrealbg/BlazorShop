@page "/terms"

<StaticPageSeo Title="Terms & Conditions"
               RelativePath="@StorefrontRoutes.Terms"
               Description="Read the current BlazorShop storefront terms, account responsibilities, and purchase conditions." />

<section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="rounded-3xl bg-white/90 border border-neutral-200/70 shadow-lg p-8 space-y-6 text-sm leading-7 text-neutral-700">
        <div>
            <h1 class="text-3xl font-extrabold tracking-tight text-neutral-900">Terms & Conditions</h1>
            <p class="mt-3">Using the BlazorShop storefront means agreeing to the current service, ordering, and account expectations.</p>
        </div>
        <div>
            <h2 class="text-xl font-bold text-neutral-900">Catalog and ordering</h2>
            <p class="mt-2">Prices, availability, and product content may change over time. Final order confirmation depends on the active purchase flow and payment completion.</p>
        </div>
        <div>
            <h2 class="text-xl font-bold text-neutral-900">Accounts</h2>
            <p class="mt-2">Customers are responsible for keeping account information accurate and for protecting their own credentials.</p>
        </div>
    </div>
</section>