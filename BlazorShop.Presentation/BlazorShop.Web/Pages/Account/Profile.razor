@page "/account/profile"

<PageTitle>Profile</PageTitle>

<section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <header class="bs-panel bs-page-hero p-8">
        <p class="bs-section-kicker">Profile</p>
        <h1 class="bs-section-title mt-3">Manage your account details</h1>
        <p class="mt-4 max-w-3xl text-base leading-7 text-slate-600">Keep your customer details current. Orders, notifications, and password changes stay on their own signed-in account pages.</p>
    </header>

    <div class="mt-8 grid gap-6 xl:grid-cols-[minmax(0,1fr)_minmax(0,1.2fr)]">
        <section class="bs-panel-soft p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Current Details</p>
            <div class="mt-5 space-y-4 text-sm text-slate-700">
                <div class="rounded-2xl border border-white/40 bg-white/80 px-4 py-4">
                    <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Name</div>
                    <div class="mt-2 text-lg font-semibold text-slate-950">@_userName</div>
                </div>
                <div class="rounded-2xl border border-white/40 bg-white/80 px-4 py-4">
                    <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Email</div>
                    <div class="mt-2 text-lg font-semibold text-slate-950">@_userEmail</div>
                </div>
            </div>

            <div class="mt-6 flex flex-wrap gap-3 text-sm font-semibold">
                <a href="/account/orders" class="bs-button bs-button-secondary">Review orders</a>
                <a href="/account/settings" class="bs-button bs-button-ghost">Security settings</a>
            </div>
        </section>

        <section class="bs-panel p-6">
            <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Edit</p>
                <h2 class="mt-2 text-2xl font-bold text-slate-950">Update your profile</h2>
            </div>

            <EditForm Model="_updateProfile" OnValidSubmit="UpdateProfileAsync" class="mt-6 space-y-4">
                <DataAnnotationsValidator />
                <div>
                    <ValidationMessage For="@(() => _updateProfile.FullName)" />
                    <FloatingTextInput class="w-full rounded-xl border border-slate-300 px-4 py-3" @bind-Value="_updateProfile.FullName" Label="Full Name" Placeholder="John Doe" />
                </div>
                <div>
                    <ValidationMessage For="@(() => _updateProfile.Email)" />
                    <FloatingTextInput class="w-full rounded-xl border border-slate-300 px-4 py-3" @bind-Value="_updateProfile.Email" Label="Email Address" Type="text" Placeholder="john@email.com" />
                </div>
                <div>
                    <FloatingTextInput class="w-full rounded-xl border border-slate-300 px-4 py-3" @bind-Value="_updateProfile.PhoneNumber" Label="Phone (optional)" Type="text" Placeholder="+359 ..." />
                </div>
                <div class="flex flex-wrap gap-3">
                    <button type="submit" class="bs-button bs-button-primary">Save changes</button>
                    <a href="/account/settings" class="bs-button bs-button-secondary">Open settings</a>
                </div>
            </EditForm>
        </section>
    </div>
</section>

@code {
    private UpdateProfileModel _updateProfile = new();
    private string _userEmail = string.Empty;
    private string _userName = string.Empty;

    [CascadingParameter]
    private Task<AuthenticationState> AuthState { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthState).User;

        var emailClaim = user.Claims.FirstOrDefault(claim => claim.Type == ClaimTypes.Email);
        if (emailClaim is not null)
        {
            _userEmail = emailClaim.Value;
            _updateProfile.Email = _userEmail;
        }

        var fullNameClaim = user.Claims.FirstOrDefault(claim => claim.Type == "FullName");
        if (fullNameClaim is not null)
        {
            _userName = fullNameClaim.Value;
            _updateProfile.FullName = fullNameClaim.Value;
        }
        else
        {
            _userName = _userEmail;
        }
    }

    private async Task UpdateProfileAsync()
    {
        var response = await AuthenticationService.UpdateProfile(_updateProfile);
        if (response.Success)
        {
            NotificationService.NotifySuccess(
                "Profile updated.",
                "Profile",
                NotificationKind.Authentication,
                link: "/account/profile");
            _userEmail = _updateProfile.Email;
            _userName = _updateProfile.FullName;
            return;
        }

        NotificationService.NotifyError(
            string.IsNullOrWhiteSpace(response.Message) ? "Unable to update profile." : response.Message,
            "Profile update failed",
            NotificationKind.Authentication,
            link: "/account/profile");
    }
}