@page "/faq"
@inject IStorefrontSeoComposer SeoComposer
@inject IStorefrontStructuredDataComposer StructuredDataComposer

<SeoHead Metadata="_metadata" StructuredData="_structuredData" />

<section class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="rounded-2xl bg-white/80 p-6 shadow sm:p-8">
        <header class="text-center">
            <h1 class="text-3xl font-extrabold tracking-tight text-neutral-900">Frequently Asked Questions</h1>
            <p class="mt-4 text-base leading-7 text-neutral-700">Quick answers about public shopping pages, product availability, and BlazorShop support.</p>
        </header>

        <div class="mt-8 space-y-4">
            @foreach (var faq in _faqs)
            {
                <details class="rounded-2xl border border-neutral-200 bg-white/70 px-5 py-4">
                    <summary class="cursor-pointer list-none font-semibold text-neutral-900">@faq.Question</summary>
                    <p class="mt-3 text-sm leading-6 text-neutral-700">@faq.Answer</p>
                </details>
            }
        </div>
    </div>
</section>

@code {
    private SeoMetadataDto _metadata = new();
    private StorefrontStructuredDataDocument _structuredData = StorefrontStructuredDataDocument.Empty;
    private readonly IReadOnlyList<StorefrontFaqStructuredDataItem> _faqs =
    [
        new("Why are product pages different now?", "The public storefront now serves product and category content on server-rendered slug routes for production SEO."),
        new("Can I still use the admin area?", "Yes. Admin capabilities remain in the existing client application and continue to use the same backend APIs."),
        new("Do all products appear publicly?", "No. Only published products with public SEO slugs are exposed through the new public catalog routes."),
        new("What about redirects for slug changes?", "Redirect automation is intentionally deferred to a later step so the route migration stays controlled and coherent."),
    ];

    protected override async Task OnParametersSetAsync()
    {
        var metadataTask = SeoComposer.ComposeStaticPageAsync(
            "Frequently Asked Questions",
            StorefrontRoutes.Faq,
            "Find quick answers about ordering, product availability, storefront pages, and general BlazorShop support.");
        var structuredDataTask = StructuredDataComposer.ComposeFaqPageAsync(
            "Frequently Asked Questions",
            StorefrontRoutes.Faq,
            "Find quick answers about ordering, product availability, storefront pages, and general BlazorShop support.",
            _faqs);

        await Task.WhenAll(metadataTask, structuredDataTask);

        _metadata = await metadataTask;
        _structuredData = await structuredDataTask;
    }
}