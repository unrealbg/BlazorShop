<header class="relative text-neutral-100">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 clip-diagonal border-b border-white/10 bg-neutral-900/95 shadow-xl"></div>

    <div class="relative mx-auto flex max-w-7xl flex-col gap-4 px-4 py-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
        <a href="@BrandHref" class="inline-flex shrink-0 flex-col leading-none select-none">
            <span class="text-sm font-extrabold tracking-wider">BLAZORSHOP</span>
            <span class="mt-1 text-[10px] text-neutral-400">@ModeLabel</span>
        </a>

        <nav class="flex flex-1 flex-wrap items-center gap-2 text-sm font-medium lg:justify-center">
            @PrimaryNavigation
        </nav>

        <div class="flex shrink-0 flex-wrap items-center gap-3 text-sm">
            @Actions
        </div>
    </div>
</header>

@code {
    [Parameter, EditorRequired]
    public string BrandHref { get; set; } = "/";

    [Parameter, EditorRequired]
    public string ModeLabel { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public RenderFragment PrimaryNavigation { get; set; } = default!;

    [Parameter, EditorRequired]
    public RenderFragment Actions { get; set; } = default!;
}