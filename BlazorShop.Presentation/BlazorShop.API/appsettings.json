{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=blazorshop;Username=postgres;Password=<set-in-user-secrets>"
  },

  "Jwt": {
    "Key": "<set-in-user-secrets>",
    "Issuer": "https://localhost:7094",
    "Audience": "https://localhost:7094"
  },
  "ClientApp": {
    "BaseUrl": "https://localhost:7258"
  },
  "Identity": {
    "RequireConfirmedAccount": true,
    "RequireConfirmedEmail": true
  },
  "Stripe": {
    "SecretKey": "<set-in-user-secrets>"
  },
  "BankTransfer": {
    "Iban": "BG00UNCR70001512345678",
    "Beneficiary": "BlazorShop Ltd.",
    "BankName": "Unicredit Bulbank",
    "AdditionalInfo": "Include the reference in the transfer reason."
  },
  "EmailSettings": {
    "From": "<required-sender-address>",
    "DisplayName": "BlazorShop",
    "SmtpServer": "<required-smtp-host>",
    "Port": 587,
    "UseSsl": false,
    "Username": "<required-smtp-username>",
    "Password": "<required-smtp-password>"
  },
  "Recommendations": {
    "MaxRecommendations": 6,
    "CacheDurationHours": 1,
    "SlidingExpirationMinutes": 30,
    "EnableOrderBasedRecommendations": true,
    "MinimumOrderCount": 5
  },
  "Runtime": {
    "Cors": {
      "AllowedOrigins": []
    },
    "ForwardedHeaders": {
      "Enabled": false,
      "KnownProxies": [],
      "KnownNetworks": [],
      "ForwardLimit": 1
    },
    "Health": {
      "ExposeInProduction": false,
      "ReadyPath": "/health",
      "LivePath": "/alive"
    },
    "Security": {
      "EnableHsts": true,
      "EnableHttpsRedirection": true,
      "RefreshTokenCookieName": "__Host-blazorshop-refresh",
      "RefreshTokenCookieSameSite": "Strict",
      "RefreshTokenLifetimeDays": 14
    },
    "RateLimiting": {
      "Enabled": true,
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "Auth": {
        "PermitLimit": 5,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    }
  }
}
