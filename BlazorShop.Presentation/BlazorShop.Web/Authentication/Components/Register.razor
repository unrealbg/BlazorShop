@page "/authentication/register"

<section class="w-full px-4 py-8 sm:px-6 lg:px-8 lg:pt-5 lg:pb-7">
  <div class="mx-auto grid w-full max-w-[66rem] items-start gap-7 lg:grid-cols-[minmax(0,1fr)_18rem] lg:gap-8 xl:w-fit xl:max-w-full xl:grid-cols-[42rem_20rem] xl:justify-center">
    <div class="bs-panel overflow-hidden">
      <div class="border-b border-slate-200 px-6 py-7 sm:px-8">
        <div class="mx-auto max-w-lg">
          <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">Account</p>
              <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-950">Create account</h1>
              <p class="mt-3 text-sm leading-6 text-slate-600">Set up the signed-in profile used for orders, notifications, and checkout continuation.</p>
            </div>

            <a href="/authentication/login/account" class="bs-button bs-button-secondary shrink-0 whitespace-nowrap">Sign in instead</a>
          </div>
        </div>
      </div>

      <div class="px-6 py-7 sm:px-8">
        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
          <div class="mx-auto mb-4 max-w-lg rounded-2xl bg-red-50 px-4 py-3 text-sm font-medium text-red-700" role="alert">
            @_errorMessage
          </div>
        }

        <div class="mx-auto max-w-lg">
          <EditForm Model="_user" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />
            <ValidationSummary class="mb-5 text-sm text-red-700" />
            <div class="mb-5">
              <ValidationMessage For="@(() => _user.FullName)" />
              <FloatingTextInput type="text" id="username" class="w-full border rounded px-3 py-2" @bind-Value="_user.FullName" Label="Full Name" placeholder="John Doe" />
            </div>
            <div class="mb-5">
              <ValidationMessage For="@(() => _user.Email)" />
              <FloatingTextInput type="text" id="email" class="w-full border rounded px-3 py-2" @bind-Value="_user.Email" Label="Email Address" Placeholder="john@email.com" />
            </div>
            <div class="mb-5">
              <ValidationMessage For="@(() => _user.Password)" />
              <FloatingTextInput id="password" class="w-full border rounded px-3 py-2" @bind-Value="_user.Password" Label="Password" Type="Password" Placeholder="My Password" />
            </div>
            <div class="mb-7">
              <ValidationMessage For="@(() => _user.ConfirmPassword)" />
              <FloatingTextInput type="Password" id="confirmPassword" class="w-full border rounded px-3 py-2" @bind-Value="_user.ConfirmPassword" Label="Confirm Password" placeholder="Confirm Password" />
            </div>
            <button class="bs-button bs-button-accent w-full disabled:opacity-60 disabled:cursor-not-allowed" type="submit" disabled="@_isLoading">@(_isLoading ? "Creating account..." : "Register")</button>
          </EditForm>
        </div>
      </div>

      <div class="border-t border-slate-200 px-6 py-5 sm:px-8">
        <div class="mx-auto flex max-w-lg flex-wrap items-center justify-between gap-3 text-sm text-slate-600">
          <span>Already have an account?</span>
          <div class="bs-shell-inline-links">
            <a href="/authentication/login/account">Login</a>
            <a href="/">Access home</a>
          </div>
        </div>
      </div>
    </div>

    <aside class="space-y-5">
      <div class="bs-panel-soft p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Account access includes</p>
        <div class="mt-5 space-y-4">
          <div class="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3 text-sm">
            <div class="font-semibold text-slate-950">Orders</div>
            <div class="mt-1 text-slate-600">History, shipment status, and confirmed order details.</div>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3 text-sm">
            <div class="font-semibold text-slate-950">Notifications</div>
            <div class="mt-1 text-slate-600">Sign-in, payment, and order updates inside the app shell.</div>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-white/80 px-4 py-3 text-sm">
            <div class="font-semibold text-slate-950">Checkout continuation</div>
            <div class="mt-1 text-slate-600">Authenticated handoff when payment and order history need your profile.</div>
          </div>
        </div>
      </div>

      <div class="bs-panel-soft p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Quick links</p>
        <div class="mt-5 flex flex-col gap-3 text-sm font-semibold">
          <a href="/authentication/login/account" class="bs-button bs-button-primary">Sign in</a>
          <a href="/" class="bs-button bs-button-ghost">Access home</a>
        </div>
      </div>
    </aside>
  </div>

  @if (_isLoading)
  {
    <div class="fixed inset-0 bg-black/20 backdrop-blur-sm grid place-items-center">
      <Spinner />
    </div>
  }
</section>
