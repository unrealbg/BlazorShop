@page "/terms"
@inject IStorefrontSeoComposer SeoComposer
@inject IStorefrontStructuredDataComposer StructuredDataComposer

<SeoHead Metadata="_metadata" StructuredData="_structuredData" />

<section class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="rounded-2xl bg-white/80 p-6 shadow sm:p-8">
        <header>
            <h1 class="text-3xl font-extrabold tracking-tight text-neutral-900">Terms & Conditions</h1>
            <p class="mt-4 text-sm leading-7 text-neutral-700">Using the BlazorShop storefront means agreeing to the current service, ordering, and account expectations.</p>
        </header>

        <div class="mt-8 space-y-4 text-sm leading-7 text-neutral-700">
            <section class="rounded-2xl border border-neutral-200 bg-white/70 p-5">
                <h2 class="text-xl font-bold text-neutral-900">Catalog and ordering</h2>
                <p class="mt-2">Prices, availability, and product content may change over time. Final order confirmation depends on the active purchase flow and payment completion.</p>
            </section>
            <section class="rounded-2xl border border-neutral-200 bg-white/70 p-5">
                <h2 class="text-xl font-bold text-neutral-900">Accounts</h2>
                <p class="mt-2">Customers are responsible for keeping account information accurate and for protecting their own credentials.</p>
            </section>
        </div>
    </div>
</section>

@code {
    private SeoMetadataDto _metadata = new();
    private StorefrontStructuredDataDocument _structuredData = StorefrontStructuredDataDocument.Empty;

    protected override async Task OnParametersSetAsync()
    {
        var metadataTask = SeoComposer.ComposeStaticPageAsync(
            "Terms & Conditions",
            StorefrontRoutes.Terms,
            "Read the current BlazorShop storefront terms, account responsibilities, and purchase conditions.");
        var structuredDataTask = StructuredDataComposer.ComposeWebPageAsync(
            "Terms & Conditions",
            StorefrontRoutes.Terms,
            "Read the current BlazorShop storefront terms, account responsibilities, and purchase conditions.");

        await Task.WhenAll(metadataTask, structuredDataTask);

        _metadata = await metadataTask;
        _structuredData = await structuredDataTask;
    }
}