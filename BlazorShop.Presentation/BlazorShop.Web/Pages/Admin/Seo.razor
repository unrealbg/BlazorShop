@page "/admin/seo"
@page "/admin/redirects"

<section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-8 mb-12 sm:mb-16">
    <div class="bs-panel bs-page-hero p-6 pb-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div>
                <p class="bs-section-kicker">Admin</p>
                <h2 class="mt-2 text-2xl font-bold text-slate-950">SEO management</h2>
                <p class="mt-3 text-sm leading-6 text-neutral-600">Manage site-wide metadata defaults and redirect governance without touching storefront routing.</p>
            </div>
            <div class="flex items-center gap-2 text-sm text-neutral-500">
                <span class="bs-chip-solid">Admin only</span>
            </div>
        </div>

        <div class="mt-4 flex flex-wrap gap-2 border-b border-neutral-200 pb-3">
            <a href="/admin/seo" class="bs-tab-button @(_activeTab == SeoAdminTab.Settings ? "bs-tab-button-active" : string.Empty)">Settings</a>
            <a href="/admin/redirects" class="bs-tab-button @(_activeTab == SeoAdminTab.Redirects ? "bs-tab-button-active" : string.Empty)">Redirects</a>
        </div>

        @if (_activeTab == SeoAdminTab.Settings)
        {
            @if (_isSettingsLoading)
            {
                <div class="bs-panel-soft mt-6 px-4 py-6 text-sm text-neutral-600">
                    Loading SEO settings…
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_settingsError))
            {
                <div class="mt-6 rounded border border-red-200 bg-red-50 px-4 py-4 text-sm text-red-700">
                    <div>@_settingsError</div>
                    <div class="mt-3">
                        <button type="button" class="bs-button bs-button-primary" @onclick="RetryLoadSettingsAsync">Retry</button>
                    </div>
                </div>
            }
            else
            {
                <EditForm Model="_settings" OnValidSubmit="SaveSettingsAsync">
                    <DataAnnotationsValidator />

                    <div class="mt-6 grid grid-cols-1 xl:grid-cols-2 gap-6">
                        <section class="bs-panel-soft p-4">
                            <div class="text-base font-semibold">Default Metadata</div>
                            <div class="mt-4 grid grid-cols-1 gap-4">
                                <div>
                                    <label class="block text-xs text-neutral-600 mb-1">Site Name</label>
                                    <InputText @bind-Value="_settings.SiteName" class="w-full border rounded px-3 py-2" />
                                    <ValidationMessage For="@(() => _settings.SiteName)" />
                                </div>
                                <div>
                                    <label class="block text-xs text-neutral-600 mb-1">Default Title Suffix</label>
                                    <InputText @bind-Value="_settings.DefaultTitleSuffix" class="w-full border rounded px-3 py-2" />
                                    <ValidationMessage For="@(() => _settings.DefaultTitleSuffix)" />
                                </div>
                                <div>
                                    <label class="block text-xs text-neutral-600 mb-1">Default Meta Description</label>
                                    <InputTextArea @bind-Value="_settings.DefaultMetaDescription" class="w-full border rounded px-3 py-2 min-h-28" />
                                    <ValidationMessage For="@(() => _settings.DefaultMetaDescription)" />
                                </div>
                                <div>
                                    <label class="block text-xs text-neutral-600 mb-1">Default Open Graph Image</label>
                                    <InputText @bind-Value="_settings.DefaultOgImage" class="w-full border rounded px-3 py-2" />
                                    <ValidationMessage For="@(() => _settings.DefaultOgImage)" />
                                </div>
                                <div>
                                    <label class="block text-xs text-neutral-600 mb-1">Base Canonical URL</label>
                                    <InputText @bind-Value="_settings.BaseCanonicalUrl" class="w-full border rounded px-3 py-2" />
                                    <ValidationMessage For="@(() => _settings.BaseCanonicalUrl)" />
                                </div>
                            </div>
                        </section>

                        <section class="bs-panel-soft p-4">
                            <div class="text-base font-semibold">Organization Metadata</div>
                            <div class="mt-4 grid grid-cols-1 gap-4">
                                <div>
                                    <label class="block text-xs text-neutral-600 mb-1">Company Name</label>
                                    <InputText @bind-Value="_settings.CompanyName" class="w-full border rounded px-3 py-2" />
                                    <ValidationMessage For="@(() => _settings.CompanyName)" />
                                </div>
                                <div>
                                    <label class="block text-xs text-neutral-600 mb-1">Company Logo URL</label>
                                    <InputText @bind-Value="_settings.CompanyLogoUrl" class="w-full border rounded px-3 py-2" />
                                    <ValidationMessage For="@(() => _settings.CompanyLogoUrl)" />
                                </div>
                                <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-xs text-neutral-600 mb-1">Company Phone</label>
                                        <InputText @bind-Value="_settings.CompanyPhone" class="w-full border rounded px-3 py-2" />
                                        <ValidationMessage For="@(() => _settings.CompanyPhone)" />
                                    </div>
                                    <div>
                                        <label class="block text-xs text-neutral-600 mb-1">Company Email</label>
                                        <InputText @bind-Value="_settings.CompanyEmail" class="w-full border rounded px-3 py-2" />
                                        <ValidationMessage For="@(() => _settings.CompanyEmail)" />
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-xs text-neutral-600 mb-1">Company Address</label>
                                    <InputTextArea @bind-Value="_settings.CompanyAddress" class="w-full border rounded px-3 py-2 min-h-28" />
                                    <ValidationMessage For="@(() => _settings.CompanyAddress)" />
                                </div>
                                <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
                                    <div>
                                        <label class="block text-xs text-neutral-600 mb-1">Facebook URL</label>
                                        <InputText @bind-Value="_settings.FacebookUrl" class="w-full border rounded px-3 py-2" />
                                        <ValidationMessage For="@(() => _settings.FacebookUrl)" />
                                    </div>
                                    <div>
                                        <label class="block text-xs text-neutral-600 mb-1">Instagram URL</label>
                                        <InputText @bind-Value="_settings.InstagramUrl" class="w-full border rounded px-3 py-2" />
                                        <ValidationMessage For="@(() => _settings.InstagramUrl)" />
                                    </div>
                                    <div>
                                        <label class="block text-xs text-neutral-600 mb-1">X URL</label>
                                        <InputText @bind-Value="_settings.XUrl" class="w-full border rounded px-3 py-2" />
                                        <ValidationMessage For="@(() => _settings.XUrl)" />
                                    </div>
                                </div>
                            </div>
                        </section>
                    </div>

                    <div class="mt-6 flex justify-end">
                        <button class="bs-button bs-button-primary disabled:opacity-60" type="submit" disabled="@_isSettingsSaving">@(_isSettingsSaving ? "Saving Settings..." : "Save Settings")</button>
                    </div>
                </EditForm>
            }
        }
        else
        {
            <div class="mt-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div>
                    <div class="text-base font-semibold">Redirect Rules</div>
                    <div class="text-sm text-neutral-600">@_redirects.Count redirect(s) configured.</div>
                </div>
                <div class="flex items-center gap-2">
                    <button type="button" class="bs-button bs-button-ghost disabled:opacity-60" @onclick="LoadRedirectsAsync" disabled="@(_isRedirectsLoading || _busyRedirectId.HasValue || _isRedirectSaving || _isRedirectDeleting)">Refresh</button>
                    <button type="button" class="bs-button bs-button-primary disabled:opacity-60" @onclick="OpenCreateRedirectDialog" disabled="@(_isRedirectsLoading || _busyRedirectId.HasValue || _isRedirectSaving || _isRedirectDeleting)">Add Redirect</button>
                </div>
            </div>

            @if (_isRedirectsLoading)
            {
                <div class="bs-panel-soft mt-4 px-4 py-6 text-sm text-neutral-600">
                    Loading SEO redirects…
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_redirectsError))
            {
                <div class="mt-4 rounded border border-red-200 bg-red-50 px-4 py-4 text-sm text-red-700">
                    <div>@_redirectsError</div>
                    <div class="mt-3">
                        <button type="button" class="bs-button bs-button-primary" @onclick="RetryLoadRedirectsAsync">Retry</button>
                    </div>
                </div>
            }
            else if (_redirects.Any())
            {
                <div class="bs-table-shell mt-4 overflow-x-auto">
                    <table class="min-w-full text-sm">
                        <thead>
                            <tr class="bg-slate-50/90 text-left">
                                <th class="px-3 py-2">Old Path</th>
                                <th class="px-3 py-2">New Path</th>
                                <th class="px-3 py-2">Code</th>
                                <th class="px-3 py-2">Status</th>
                                <th class="px-3 py-2">Created</th>
                                <th class="px-3 py-2 text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-neutral-200">
                            @foreach (var redirect in _redirects)
                            {
                                <tr>
                                    <td class="px-3 py-2 font-mono text-xs">@redirect.OldPath</td>
                                    <td class="px-3 py-2 font-mono text-xs">@redirect.NewPath</td>
                                    <td class="px-3 py-2">
                                        <span class="rounded-full bg-neutral-100 px-2 py-1 text-xs font-semibold text-neutral-700">@redirect.StatusCode</span>
                                    </td>
                                    <td class="px-3 py-2">
                                        <span class="rounded-full px-2 py-1 text-xs font-semibold @(redirect.IsActive ? "bg-emerald-100 text-emerald-700" : "bg-neutral-100 text-neutral-600")">@(redirect.IsActive ? "Active" : "Inactive")</span>
                                    </td>
                                    <td class="px-3 py-2">@redirect.CreatedOn.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                    <td class="px-3 py-2">
                                        <div class="flex items-center justify-center gap-3">
                                            <button type="button" class="bs-subtle-action-link disabled:opacity-60" @onclick="() => OpenEditRedirectDialog(redirect)" disabled="@(_busyRedirectId.HasValue || _isRedirectSaving || _isRedirectDeleting)">Edit</button>
                                            @if (redirect.IsActive)
                                            {
                                                <button type="button" class="text-amber-700 transition hover:text-amber-800 disabled:opacity-60" @onclick="() => DeactivateRedirectAsync(redirect.Id)" disabled="@(_busyRedirectId.HasValue || _isRedirectSaving || _isRedirectDeleting)">@(redirect.Id == _busyRedirectId ? _busyRedirectAction ?? "Deactivating..." : "Deactivate")</button>
                                            }
                                            <button type="button" class="text-red-700 transition hover:text-red-800 disabled:opacity-60" @onclick="() => ConfirmDeleteRedirect(redirect)" disabled="@(_busyRedirectId.HasValue || _isRedirectSaving || _isRedirectDeleting)">Delete</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="bs-panel-soft mt-4 px-6 py-5 text-center font-semibold text-blue-800">
                    No redirect rules configured yet.
                </div>
            }
        }
    </div>
</section>

<ModalDialog @bind-IsVisible="_showRedirectDialog">
    <Header>
        <h5 class="text-lg font-semibold">@(_editingRedirectId.HasValue ? "Edit Redirect" : "Add Redirect")</h5>
    </Header>
    <Body>
        <EditForm Model="_redirectForm" OnValidSubmit="SaveRedirectAsync">
            <DataAnnotationsValidator />
            <div class="space-y-4">
                <div>
                    <label class="block text-xs text-neutral-600 mb-1">Old Path</label>
                    <InputText @bind-Value="_redirectForm.OldPath" class="w-full border rounded px-3 py-2" />
                    <ValidationMessage For="@(() => _redirectForm.OldPath)" />
                </div>
                <div>
                    <label class="block text-xs text-neutral-600 mb-1">New Path</label>
                    <InputText @bind-Value="_redirectForm.NewPath" class="w-full border rounded px-3 py-2" />
                    <ValidationMessage For="@(() => _redirectForm.NewPath)" />
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs text-neutral-600 mb-1">Status Code</label>
                        <InputSelect @bind-Value="_redirectForm.StatusCode" class="w-full border rounded px-3 py-2">
                            <option value="301">301 Permanent</option>
                            <option value="302">302 Temporary</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => _redirectForm.StatusCode)" />
                    </div>
                    <div class="flex items-end">
                        <label class="inline-flex items-center gap-2 text-sm text-neutral-700">
                            <InputCheckbox @bind-Value="_redirectForm.IsActive" class="h-4 w-4" />
                            <span>Active</span>
                        </label>
                    </div>
                </div>
            </div>

            <hr class="my-4" />
            <div class="flex justify-end gap-2">
                <button class="bs-button bs-button-primary disabled:opacity-60" type="submit" disabled="@_isRedirectSaving">@(_isRedirectSaving ? (_editingRedirectId.HasValue ? "Saving..." : "Creating...") : "Save")</button>
                <button class="bs-button bs-button-ghost disabled:opacity-60" type="button" @onclick="CancelRedirectEdit" disabled="@_isRedirectSaving">Cancel</button>
            </div>
        </EditForm>
    </Body>
</ModalDialog>

<ModalDialog @bind-IsVisible="_showDeleteRedirectDialog">
    <Header>
        <h5 class="text-lg font-semibold">Delete Redirect</h5>
    </Header>
    <Body>
        <div class="text-sm text-neutral-700">
            Are you sure you want to delete the redirect for <span class="font-mono">@_redirectToDeletePath</span>?
        </div>
    </Body>
    <Footer>
        <button class="bs-button bs-button-danger disabled:opacity-60" @onclick="DeleteRedirectConfirmedAsync" disabled="@_isRedirectDeleting">@(_isRedirectDeleting ? "Deleting..." : "Delete")</button>
        <button class="bs-button bs-button-ghost disabled:opacity-60" @onclick="CancelDeleteRedirect" disabled="@_isRedirectDeleting">Cancel</button>
    </Footer>
</ModalDialog>