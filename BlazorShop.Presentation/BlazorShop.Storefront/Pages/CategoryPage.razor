@page "/category/{Slug}"
@inject StorefrontApiClient ApiClient
@inject IStorefrontSeoComposer SeoComposer
@inject IStorefrontStructuredDataComposer StructuredDataComposer

<SeoHead Metadata="_metadata" StructuredData="_structuredData" />

@if (_isServiceUnavailable)
{
    <ServiceUnavailableState Title="Category temporarily unavailable"
                             Message="The storefront is running, but the catalog API is not reachable right now. Start the API project or AppHost and refresh this page." />
}
else if (_isNotFound)
{
    <NotFoundState Title="Category not found"
                   Message="We couldn't find a published category for this address." />
}
else if (_categoryPage is not null)
{
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
        <BreadcrumbNav Items="_breadcrumbs" ClassName="mb-6" />

        <div class="rounded-3xl bg-white/90 border border-neutral-200/70 shadow-lg p-8">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Category</p>
            <h1 class="mt-2 text-4xl font-extrabold tracking-tight">@_categoryPage.Category.Name</h1>
            @if (!string.IsNullOrWhiteSpace(_categoryPage.Category.MetaDescription))
            {
                <p class="mt-4 max-w-3xl text-base leading-7 text-neutral-700">@_categoryPage.Category.MetaDescription</p>
            }
        </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-14">
        <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Published Products</p>
            <h2 class="mt-2 text-3xl font-extrabold tracking-tight">Browse @_categoryPage.Category.Name</h2>
        </div>

        <ProductGrid Products="_categoryPage.Products"
                     EmptyMessage="This published category does not have any public products yet." />
    </section>

    <SeoContentSection Title="@CategorySeoContentTitle"
                       Eyebrow="Category Guide"
                       Content="@_categoryPage.Category.SeoContent" />
}

@code {
    private GetCategoryPage? _categoryPage;
    private bool _isNotFound;
    private bool _isServiceUnavailable;
    private SeoMetadataDto _metadata = new();
    private IReadOnlyList<StorefrontBreadcrumbItem> _breadcrumbs = [];
    private StorefrontStructuredDataDocument _structuredData = StorefrontStructuredDataDocument.Empty;

    private string CategorySeoContentTitle => _categoryPage is null
        ? string.Empty
        : $"More about {_categoryPage.Category.Name}";

    [Parameter]
    public string Slug { get; set; } = string.Empty;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        var categoryPageResult = await ApiClient.GetPublishedCategoryBySlugAsync(Slug);

        if (categoryPageResult.IsServiceUnavailable)
        {
            _categoryPage = null;
            _isNotFound = false;
            _isServiceUnavailable = true;
            _breadcrumbs = [];
            _structuredData = StorefrontStructuredDataDocument.Empty;
            if (HttpContext is not null)
            {
                HttpContext.Response.StatusCode = StatusCodes.Status503ServiceUnavailable;
            }

            _metadata = await SeoComposer.ComposeServiceUnavailablePageAsync(
                "Category temporarily unavailable",
                StorefrontRoutes.Category(Slug),
                "The storefront is running, but the catalog API is not reachable right now.");
            return;
        }

        _categoryPage = categoryPageResult.Value;

        if (_categoryPage is null)
        {
            _isNotFound = true;
            _isServiceUnavailable = false;
            _breadcrumbs = [];
            _structuredData = StorefrontStructuredDataDocument.Empty;
            if (HttpContext is not null)
            {
                HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
            }

            _metadata = await SeoComposer.ComposeNotFoundPageAsync(
                "Category not found",
                StorefrontRoutes.Category(Slug),
                "We couldn't find a published category for this address.");
            return;
        }

        _isNotFound = false;
        _isServiceUnavailable = false;
        _breadcrumbs =
        [
            new StorefrontBreadcrumbItem("Home", StorefrontRoutes.Home),
            new StorefrontBreadcrumbItem(_categoryPage.Category.Name ?? "Category"),
        ];
        _metadata = await SeoComposer.ComposeCategoryPageAsync(_categoryPage.Category);
        _structuredData = await StructuredDataComposer.ComposeCategoryPageAsync(_categoryPage.Category);
    }
}