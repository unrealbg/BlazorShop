@page "/payment-success"
@page "/payment-success/{bt:int?}"

<section class="success-payment">
    <div class="card shadow-sm success-payment-card">
        <div class="card-header text-center">
            <h4 class="mb-0">Payment Success</h4>
        </div>
        <div class="card-body">
            <div class="alert alert-success text-center" role="alert">
                <h4 class="alert-heading">Thank you for your purchase!</h4>
                <p>Your payment was successful. Your order will be delivered soon.</p>
                <hr>
                <p class="mb-0">You can track your order in the <a href="/my-orders">My Orders</a> page.</p>
            </div>
        </div>
    </div>
</section>

@code {
    [CascadingParameter]
    public Task<AuthenticationState>? UserAuthState { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "bt")]
    public int? Bt { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var isBankTransfer = Bt.GetValueOrDefault() == 1;

        try
        {
            if (UserAuthState is null)
            {
                return;
            }

            var authState = await UserAuthState;
            var user = authState?.User;
            if (user?.Identity?.IsAuthenticated == true)
            {
                var cartString = await CookieStorageService.GetAsync(Constant.Cart.Name);
                if (!string.IsNullOrEmpty(cartString))
                {
                    var list = JsonSerializer.Deserialize<IEnumerable<ProcessCart>>(cartString) ?? Enumerable.Empty<ProcessCart>();
                    var userId = user.Claims.FirstOrDefault(x => x.Type == ClaimTypes.NameIdentifier)?.Value;

                    if (!string.IsNullOrEmpty(userId) && list.Any())
                    {
                        if (!isBankTransfer)
                        {
                            var arc = list.Select(x => new CreateOrderItem
                            {
                                ProductId = x.ProductId,
                                Quantity = x.Quantity,
                                UserId = userId
                            });

                            var historyResult = await CartService.SaveCheckoutHistory(arc);

                            if (historyResult.Success)
                            {
                                NotificationService.NotifySuccess(
                                    "Your order was placed successfully.",
                                    "Order placed",
                                    NotificationKind.Order,
                                    link: "/my-orders");
                            }
                            else
                            {
                                NotificationService.NotifyWarning(
                                    "Your payment completed, but we could not refresh your order history right now.",
                                    "Order update",
                                    NotificationKind.Order,
                                    link: "/my-orders");
                            }
                        }
                        else
                        {
                            NotificationService.NotifyInfo(
                                "Your order has been placed. Complete the bank transfer using the checkout instructions.",
                                "Payment pending",
                                NotificationKind.Payment,
                                link: "/my-orders");
                        }

                        await CookieStorageService.RemoveAsync(Constant.Cart.Name);
                    }
                }
            }
        }
        catch
        {
            NotificationService.NotifyWarning(
                "Your payment was processed, but we could not update the local order state completely.",
                "Order update",
                NotificationKind.Order,
                link: "/my-orders");
        }
    }
}
