@using BlazorShop.Web.Shared.Models.Seo

<div class="space-y-5">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div>
            <label class="block text-xs text-neutral-600 mb-1">Slug</label>
            <InputText @bind-Value="Model.Slug" class="w-full border rounded px-3 py-2" />
            <ValidationMessage For="@(() => Model.Slug)" />
            <div class="mt-1 text-xs text-neutral-500">Required when the entry is published.</div>
        </div>
        <div>
            <label class="block text-xs text-neutral-600 mb-1">Canonical URL</label>
            <InputText @bind-Value="Model.CanonicalUrl" class="w-full border rounded px-3 py-2" />
            <ValidationMessage For="@(() => Model.CanonicalUrl)" />
        </div>
        <div>
            <label class="block text-xs text-neutral-600 mb-1">Meta Title</label>
            <InputText @bind-Value="Model.MetaTitle" class="w-full border rounded px-3 py-2" />
            <ValidationMessage For="@(() => Model.MetaTitle)" />
        </div>
        <div>
            <label class="block text-xs text-neutral-600 mb-1">Open Graph Title</label>
            <InputText @bind-Value="Model.OgTitle" class="w-full border rounded px-3 py-2" />
            <ValidationMessage For="@(() => Model.OgTitle)" />
        </div>
        <div>
            <label class="block text-xs text-neutral-600 mb-1">Meta Description</label>
            <InputTextArea @bind-Value="Model.MetaDescription" class="w-full border rounded px-3 py-2 min-h-28" />
            <ValidationMessage For="@(() => Model.MetaDescription)" />
        </div>
        <div>
            <label class="block text-xs text-neutral-600 mb-1">Open Graph Description</label>
            <InputTextArea @bind-Value="Model.OgDescription" class="w-full border rounded px-3 py-2 min-h-28" />
            <ValidationMessage For="@(() => Model.OgDescription)" />
        </div>
        <div class="lg:col-span-2">
            <label class="block text-xs text-neutral-600 mb-1">Open Graph Image</label>
            <InputText @bind-Value="Model.OgImage" class="w-full border rounded px-3 py-2" />
            <ValidationMessage For="@(() => Model.OgImage)" />
        </div>
    </div>

    <div class="rounded border bg-neutral-50 px-4 py-3">
        <div class="text-sm font-semibold text-neutral-800">Indexing Controls</div>
        <div class="mt-3 flex flex-wrap gap-6">
            <label class="inline-flex items-center gap-2 text-sm text-neutral-700">
                <InputCheckbox @bind-Value="Model.IsPublished" class="h-4 w-4" />
                <span>Published</span>
            </label>
            <label class="inline-flex items-center gap-2 text-sm text-neutral-700">
                <InputCheckbox @bind-Value="Model.RobotsIndex" class="h-4 w-4" />
                <span>Allow indexing</span>
            </label>
            <label class="inline-flex items-center gap-2 text-sm text-neutral-700">
                <InputCheckbox @bind-Value="Model.RobotsFollow" class="h-4 w-4" />
                <span>Allow follow</span>
            </label>
        </div>
        @if (Model.IsPublished && string.IsNullOrWhiteSpace(Model.Slug))
        {
            <div class="mt-3 rounded border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-800">
                Published entries need a slug before the backend will accept the update.
            </div>
        }
    </div>

    <div>
        <label class="block text-xs text-neutral-600 mb-1">SEO Content</label>
        <InputTextArea @bind-Value="Model.SeoContent" class="w-full border rounded px-3 py-2 min-h-40" />
        <ValidationMessage For="@(() => Model.SeoContent)" />
    </div>
</div>

@code {
    [Parameter]
    [EditorRequired]
    public SeoFieldsBase Model { get; set; } = default!;
}