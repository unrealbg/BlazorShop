<section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="rounded-3xl border border-amber-200 bg-amber-50/95 p-8 shadow-lg text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-amber-700">Service Unavailable</p>
        <h1 class="mt-3 text-3xl font-extrabold tracking-tight text-neutral-900">@Title</h1>
        <p class="mt-4 text-sm leading-6 text-neutral-700">@Message</p>
        <a href="@StorefrontRoutes.Home" class="mt-6 inline-flex items-center rounded-md bg-neutral-900 px-4 py-2 text-sm font-semibold text-white hover:bg-neutral-800">
            Return to Home
        </a>
    </div>
</section>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Message { get; set; } = string.Empty;
}