@page "/admin/orders"
@using BlazorShop.Web.Services
@inject IAdminOrderService AdminOrderService

<section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 mt-8 mb-12 sm:mb-16">
  <div class="bs-panel bs-page-hero p-6 admin-panel">
    <header class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="bs-section-kicker">Admin</p>
        <h2 class="mt-2 text-2xl font-bold text-slate-950">Orders by customer</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">Review grouped customer orders, shipping state, and tracking details without leaving the admin surface.</p>
      </div>
      <div class="bs-toolbar-cluster">
        <input class="border rounded px-2 py-1 text-sm w-60" placeholder="Search name/email" @bind="_customerQuery" />
        <button class="bs-button bs-button-ghost disabled:opacity-60" @onclick="ToggleAll" disabled="@_isLoading">@(_allExpanded ? "Collapse All" : "Expand All")</button>
        <button class="bs-button bs-button-secondary disabled:opacity-60" @onclick="ExportCsvAsync" disabled="@(_isLoading || !_orders.Any())">Export CSV</button>
        <button class="bs-button bs-button-primary disabled:opacity-60 disabled:cursor-not-allowed" @onclick="ReloadAsync" disabled="@(_isLoading || _isSaving)">@(_isLoading ? "Reloading..." : "Reload")</button>
      </div>
    </header>

    <div class="mt-4 space-y-4">
      @if (_isLoading)
      {
        <div class="bs-panel-soft mt-6 px-6 py-5 text-center text-sm text-neutral-600">Loading orders...</div>
      }
      else if (!string.IsNullOrWhiteSpace(_loadError))
      {
        <div class="mt-6 rounded border border-red-200 bg-red-50 px-6 py-5 text-center text-sm text-red-700">
          <div>@_loadError</div>
          <div class="mt-4">
            <button type="button" class="bs-button bs-button-primary" @onclick="ReloadAsync">Retry</button>
          </div>
        </div>
      }
      else if (_orders.Any())
      {
        var groups = _orders
            .GroupBy(o => new { o.UserId, Name = o.CustomerName ?? o.CustomerEmail ?? "(Unknown)", Email = o.CustomerEmail })
            .OrderBy(g => g.Key.Name)
            .Where(g => string.IsNullOrWhiteSpace(_customerQuery)
                || (g.Key.Name?.Contains(_customerQuery, StringComparison.OrdinalIgnoreCase) ?? false)
                || (g.Key.Email?.Contains(_customerQuery, StringComparison.OrdinalIgnoreCase) ?? false));

        @foreach (var g in groups)
        {
          var key = g.Key.UserId ?? g.Key.Name;
          bool isOpen = _expanded.Contains(key);

          <article class="bs-table-shell overflow-hidden">
            <button type="button" class="flex w-full flex-col items-start justify-between gap-3 bg-slate-50/90 px-4 py-3 sm:flex-row sm:items-center" @onclick="() => Toggle(key)">
              <div class="text-left">
                <div class="font-semibold break-all">@g.Key.Name</div>
                <div class="text-xs text-neutral-600 break-all">@g.Key.Email</div>
              </div>
              <div class="text-right shrink-0">
                <div class="text-sm">Orders: <b>@g.Count()</b></div>
                <div class="text-sm">Total: <b>EUR @g.Sum(x => x.TotalAmount).ToString("F2")</b></div>
              </div>
            </button>

            @if (isOpen)
            {
              <div class="p-3 space-y-3">
                @foreach (var o in g.OrderByDescending(x => x.CreatedOn))
                {
                  <div class="bs-panel-soft overflow-hidden p-0">
                    <div class="flex flex-col gap-2 bg-slate-50/80 px-3 py-3 sm:flex-row sm:items-center sm:justify-between">
                      <div class="text-sm flex items-center gap-2 flex-wrap">
                        <span><span class="font-semibold">Ref:</span> @o.Reference</span>
                        <button class="bs-subtle-action-link text-xs" @onclick="() => CopyAsync(o.Reference)">Copy</button>
                        <span class="ml-2"><span class="font-semibold">Date:</span> @o.CreatedOn.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                        <button class="bs-subtle-action-link text-xs" @onclick="() => OpenDetailsDialog(o)">Details</button>
                      </div>
                      <div class="text-sm">
                        <span class="mr-3">Status: <b>@o.ShippingStatus</b></span>
                        <button class="bs-subtle-action-link" @onclick="() => OpenTrackDialog(o)">Edit</button>
                      </div>
                    </div>
                    <div class="p-3 overflow-x-auto">
                      <table class="bs-table-wide min-w-full table-fixed text-xs">
                        <colgroup>
                          <col class="w-[56%] sm:w-[52%]" />
                          <col class="w-[10%] sm:w-[8%]" />
                          <col class="w-[16%] sm:w-[14%]" />
                          <col class="w-[16%] sm:w-[14%]" />
                          <col class="w-[24%] sm:w-[12%]" />
                        </colgroup>
                        <thead>
                          <tr class="bg-neutral-50 text-left">
                            <th class="px-2 py-1">Product</th>
                            <th class="px-2 py-1">Qty</th>
                            <th class="px-2 py-1">Unit (EUR)</th>
                            <th class="px-2 py-1">Total (EUR)</th>
                            <th class="px-2 py-1">Tracking</th>
                          </tr>
                        </thead>
                        <tbody class="divide-y divide-neutral-200">
                          @foreach (var l in o.Lines)
                          {
                            <tr class="align-middle h-9">
                              <td class="px-2 py-1"><Tooltip Text="@l.ProductName"><div class="truncate" title="@l.ProductName">@l.ProductName</div></Tooltip></td>
                              <td class="px-2 py-1">@l.Quantity</td>
                              <td class="px-2 py-1">@l.UnitPrice.ToString("F2")</td>
                              <td class="px-2 py-1">@((l.UnitPrice * l.Quantity).ToString("F2"))</td>
                              <td class="px-2 py-1">
                                <div class="flex items-center gap-2">
                                  @if (!string.IsNullOrWhiteSpace(o.TrackingUrl))
                                  {
                                    <Tooltip Text="@o.TrackingUrl">
                                      <a class="bs-subtle-action-link truncate max-w-[10rem] sm:max-w-none" href="@o.TrackingUrl" target="_blank" rel="noopener">Track</a>
                                    </Tooltip>
                                    <button class="bs-subtle-action-link text-xs" @onclick="() => CopyAsync(o.TrackingUrl!)">Copy</button>
                                  }
                                  else if (!string.IsNullOrWhiteSpace(o.TrackingNumber))
                                  {
                                    <Tooltip Text="@o.TrackingNumber">
                                      <span class="text-neutral-600 truncate max-w-[10rem] sm:max-w-none">@o.TrackingNumber</span>
                                    </Tooltip>
                                    <button class="bs-subtle-action-link text-xs" @onclick="() => CopyAsync(o.TrackingNumber!)">Copy</button>
                                  }
                                  else
                                  {
                                    <span class="text-neutral-500">Pending</span>
                                  }
                                </div>
                              </td>
                            </tr>
                          }
                        </tbody>
                      </table>
                      <div class="mt-2 text-right text-sm font-semibold">Order Total: EUR @o.TotalAmount.ToString("F2")</div>
                      <div class="text-right text-xs text-neutral-600">
                        @if (o.ShippedOn.HasValue) {<span class="mr-3">Shipped: @o.ShippedOn.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>}
                        @if (o.DeliveredOn.HasValue) {<span>Delivered: @o.DeliveredOn.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>}
                      </div>
                    </div>
                  </div>
                }
              </div>
            }
          </article>
        }
      }
      else
      {
        <div class="bs-panel-soft mt-6 px-6 py-5 text-center font-semibold text-blue-800">No orders</div>
      }
    </div>
  </div>
</section>

<ModalDialog @bind-IsVisible="_showDialog">
  <Header>
    <h5 class="text-lg font-semibold">Edit Tracking</h5>
  </Header>
  <Body>
    <div class="space-y-2">
      <div class="text-xs text-neutral-600">Order: @_editOrder?.Reference <button class="bs-subtle-action-link text-xs" @onclick="() => CopyAsync(_editOrder?.Reference ?? string.Empty)">Copy</button></div>
      <input class="border rounded w-full px-2 py-1" placeholder="Carrier" @bind="_carrier" />
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
        <input class="border rounded w-full px-2 py-1" placeholder="Tracking Number" @bind="_trackingNumber" />
        <button class="bs-subtle-action-link shrink-0 text-xs" @onclick="() => CopyAsync(_trackingNumber)">Copy</button>
      </div>
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
        <input class="border rounded w-full px-2 py-1" placeholder="Tracking Url" @bind="_trackingUrl" />
        <button class="bs-subtle-action-link shrink-0 text-xs" @onclick="() => CopyAsync(_trackingUrl)">Copy</button>
      </div>
      <select class="border rounded w-full px-2 py-1" @bind="_shippingStatus">
        <option>PendingShipment</option>
        <option>Shipped</option>
        <option>InTransit</option>
        <option>OutForDelivery</option>
        <option>Delivered</option>
      </select>
      <textarea class="border rounded w-full px-2 py-1 min-h-24" placeholder="Admin note" @bind="_adminNote"></textarea>
    </div>
  </Body>
  <Footer>
    <button class="bs-button bs-button-primary disabled:opacity-60 disabled:cursor-not-allowed" @onclick="SaveAsync" disabled="@_isSaving">@(_isSaving ? "Saving..." : "Save")</button>
    <button class="bs-button bs-button-secondary ml-2 disabled:opacity-60" @onclick="() => _showDialog = false" disabled="@_isSaving">Close</button>
  </Footer>
</ModalDialog>

<ModalDialog @bind-IsVisible="_showDetailsDialog" Size="xl">
  <Header>
    <h5 class="text-lg font-semibold">Order Details</h5>
  </Header>
  <Body>
    @if (_detailsOrder is not null)
    {
      <div class="grid grid-cols-1 gap-4 text-sm lg:grid-cols-2">
        <section class="bs-panel-soft p-4">
          <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Customer</div>
          <div class="mt-2 font-semibold text-slate-950">@(_detailsOrder.CustomerName ?? "(Unknown)")</div>
          <div class="mt-1 break-all text-slate-600">@_detailsOrder.CustomerEmail</div>
          <div class="mt-1 break-all text-slate-500">@_detailsOrder.UserId</div>
        </section>
        <section class="bs-panel-soft p-4">
          <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Fulfillment</div>
          <div class="mt-2 text-slate-950">@_detailsOrder.ShippingStatus</div>
          <div class="mt-1 text-slate-600">@_detailsOrder.ShippingCarrier @_detailsOrder.TrackingNumber</div>
          <div class="mt-1 break-all text-slate-500">@_detailsOrder.TrackingUrl</div>
        </section>
      </div>
      <div class="bs-table-shell mt-4 overflow-x-auto">
        <table class="bs-table-compact min-w-full text-sm">
          <thead><tr><th class="px-3 py-2 text-left">Product</th><th class="px-3 py-2 text-left">Qty</th><th class="px-3 py-2 text-left">Unit</th><th class="px-3 py-2 text-left">Total</th></tr></thead>
          <tbody class="divide-y divide-slate-200">
            @foreach (var line in _detailsOrder.Lines)
            {
              <tr><td class="px-3 py-2">@line.ProductName</td><td class="px-3 py-2">@line.Quantity</td><td class="px-3 py-2">@line.UnitPrice.ToString("F2")</td><td class="px-3 py-2">@((line.UnitPrice * line.Quantity).ToString("F2"))</td></tr>
            }
          </tbody>
        </table>
      </div>
      <div class="mt-4 rounded border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">@(!string.IsNullOrWhiteSpace(_detailsOrder.AdminNote) ? _detailsOrder.AdminNote : "No admin note.")</div>
    }
  </Body>
  <Footer>
    <button class="bs-button bs-button-ghost" @onclick="() => _showDetailsDialog = false">Close</button>
  </Footer>
</ModalDialog>

@code {
  private List<GetOrder> _orders = new();
  private bool _isLoading;
  private bool _isSaving;
  private string? _loadError;
  private bool _showDialog;
  private GetOrder? _editOrder;
  private string _carrier = string.Empty;
  private string _trackingNumber = string.Empty;
  private string _trackingUrl = string.Empty;
  private string _shippingStatus = "PendingShipment";
  private string? _adminNote;
  private bool _showDetailsDialog;
  private GetOrder? _detailsOrder;

  private string _customerQuery = string.Empty;
  private bool _allExpanded = false;
  private HashSet<string> _expanded = new();

  [Inject] private IJSRuntime JS { get; set; } = default!;

  protected override async Task OnInitializedAsync()
  {
      await ReloadAsync();
  }

  private async Task ReloadAsync()
  {
    _isLoading = true;
    _loadError = null;

    var ordersResult = await AdminOrderService.GetAsync(new AdminOrderQuery { PageSize = 100 });

    if (QueryFailureNotifier.TryNotifyFailure(ordersResult, "Orders", showToast: false))
    {
      _orders = new();
      _loadError = FeedbackMessageResolver.ResolveQueryFailure(ordersResult, "We couldn't load orders right now. Please try again.");
      _expanded.Clear();
      _allExpanded = false;
      _isLoading = false;
      return;
    }

    _orders = (ordersResult.Data?.Items ?? []).ToList();

    _expanded.Clear();
    _allExpanded = false;
    _isLoading = false;
  }

  private void Toggle(string key)
  {
    if (_expanded.Contains(key)) _expanded.Remove(key); else _expanded.Add(key);
    StateHasChanged();
  }

  private void ToggleAll()
  {
    if (_allExpanded)
    {
      _expanded.Clear();
      _allExpanded = false;
    }
    else
    {
      _expanded = _orders
        .Select(o => o.UserId ?? (o.CustomerName ?? o.CustomerEmail ?? string.Empty))
        .Distinct()
        .ToHashSet();
      _allExpanded = true;
    }
  }

  private void OpenTrackDialog(GetOrder order)
  {
    _editOrder = order;
    _carrier = order.ShippingCarrier ?? string.Empty;
    _trackingNumber = order.TrackingNumber ?? string.Empty;
    _trackingUrl = order.TrackingUrl ?? string.Empty;
    _shippingStatus = order.ShippingStatus;
    _adminNote = order.AdminNote;
    _showDialog = true;
  }

  private void OpenDetailsDialog(GetOrder order)
  {
    _detailsOrder = order;
    _showDetailsDialog = true;
  }

  private async Task SaveAsync()
  {
    if (_editOrder is null || _isSaving) return;

    _isSaving = true;

    try
    {
      var tRes = await AdminOrderService.UpdateTrackingAsync(_editOrder.Id, new UpdateTrackingRequest { Carrier = _carrier, TrackingNumber = _trackingNumber, TrackingUrl = _trackingUrl });
      var sRes = await AdminOrderService.UpdateShippingStatusAsync(_editOrder.Id, new UpdateShippingStatusRequest { ShippingStatus = _shippingStatus });
      var nRes = await AdminOrderService.UpdateAdminNoteAsync(_editOrder.Id, new UpdateOrderAdminNote { AdminNote = _adminNote });

      _showDialog = false;

      if (tRes.Success && sRes.Success && nRes.Success)
      {
        ToastService.ShowToast(Shared.Toast.ToastLevel.Success, "Order updates saved successfully.", "Orders");
        await ReloadAsync();
      }
      else
      {
        ToastService.ShowToast(Shared.Toast.ToastLevel.Error, "We couldn't save those order updates. Try again.", "Orders");
      }
    }
    finally
    {
      _isSaving = false;
    }
  }

  private async Task CopyAsync(string? text)
  {
    if (string.IsNullOrEmpty(text)) return;
    try
    {
      await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
      ToastService.ShowSuccessToast("Copied to clipboard");
    }
    catch
    {
      ToastService.ShowErrorToast("Copy failed");
    }
  }

  private async Task ExportCsvAsync()
  {
    var rows = FilteredOrders()
      .Select(o => new[]
      {
        o.Reference,
        o.CreatedOn.ToLocalTime().ToString("yyyy-MM-dd HH:mm"),
        o.CustomerName ?? string.Empty,
        o.CustomerEmail ?? string.Empty,
        o.Status,
        o.ShippingStatus,
        o.TotalAmount.ToString("F2"),
        o.TrackingNumber ?? string.Empty,
      });

    var csv = string.Join(Environment.NewLine, new[] { "Reference,Created,Customer,Email,Status,ShippingStatus,Total,Tracking" }
      .Concat(rows.Select(row => string.Join(",", row.Select(EscapeCsv)))));

    await JS.InvokeVoidAsync("navigator.clipboard.writeText", csv);
    ToastService.ShowSuccessToast("Filtered orders CSV copied to clipboard.", "Orders");
  }

  private IEnumerable<GetOrder> FilteredOrders()
  {
    return _orders.Where(o => string.IsNullOrWhiteSpace(_customerQuery)
        || (o.CustomerName?.Contains(_customerQuery, StringComparison.OrdinalIgnoreCase) ?? false)
        || (o.CustomerEmail?.Contains(_customerQuery, StringComparison.OrdinalIgnoreCase) ?? false));
  }

  private static string EscapeCsv(string value)
  {
    return "\"" + value.Replace("\"", "\"\"") + "\"";
  }
}
