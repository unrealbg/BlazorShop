@page "/customer-service"
@inject IStorefrontSeoComposer SeoComposer
@inject IStorefrontStructuredDataComposer StructuredDataComposer

<SeoHead Metadata="_metadata" StructuredData="_structuredData" />

<section class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="rounded-2xl bg-white/80 p-6 shadow sm:p-8">
        <header class="text-center">
            <h1 class="text-3xl font-extrabold tracking-tight text-neutral-900">Customer Service</h1>
            <p class="mt-4 text-base leading-7 text-neutral-700">Our support team can help with orders, catalog questions, and general storefront issues.</p>
        </header>

        <div class="mt-8 grid gap-6 md:grid-cols-2">
            <div class="rounded-2xl border border-neutral-200 bg-white/70 p-6">
                <h2 class="text-lg font-bold text-neutral-900">Contact</h2>
                <ul class="mt-4 space-y-2 text-sm text-neutral-700">
                    <li>Email: support@yourstore.com</li>
                    <li>Phone: +1 123-456-7890</li>
                    <li>Address: 123 Main Street, Your City, Your Country</li>
                </ul>
            </div>
            <div class="rounded-2xl border border-neutral-200 bg-white/70 p-6">
                <h2 class="text-lg font-bold text-neutral-900">Need answers first?</h2>
                <p class="mt-3 text-sm leading-6 text-neutral-700">Start with the FAQ for common questions about catalog content, orders, and storefront behavior.</p>
                <a href="@StorefrontRoutes.Faq" class="mt-4 inline-flex items-center rounded bg-neutral-900 px-4 py-2 font-semibold text-white hover:bg-neutral-800">Visit FAQ</a>
            </div>
        </div>
    </div>
</section>

@code {
    private SeoMetadataDto _metadata = new();
    private StorefrontStructuredDataDocument _structuredData = StorefrontStructuredDataDocument.Empty;

    protected override async Task OnParametersSetAsync()
    {
        var metadataTask = SeoComposer.ComposeStaticPageAsync(
            "Customer Service",
            StorefrontRoutes.CustomerService,
            "Contact BlazorShop customer service for order assistance, product questions, and storefront support.");
        var structuredDataTask = StructuredDataComposer.ComposeWebPageAsync(
            "Customer Service",
            StorefrontRoutes.CustomerService,
            "Contact BlazorShop customer service for order assistance, product questions, and storefront support.");

        await Task.WhenAll(metadataTask, structuredDataTask);

        _metadata = await metadataTask;
        _structuredData = await structuredDataTask;
    }
}