<article class="group relative rounded-2xl bg-white/95 border border-neutral-200/70 shadow-md hover:shadow-2xl transition-all duration-300 overflow-hidden hover:-translate-y-0.5">
    <div class="p-6">
        @if (!string.IsNullOrWhiteSpace(Product.CategoryName))
        {
            <div class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500">
                @if (!string.IsNullOrWhiteSpace(Product.CategorySlug))
                {
                    <a href="@StorefrontRoutes.Category(Product.CategorySlug)" class="hover:text-neutral-900">@Product.CategoryName</a>
                }
                else
                {
                    <span>@Product.CategoryName</span>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Product.Slug))
        {
            <a href="@StorefrontRoutes.Product(Product.Slug)" class="block">
                <h2 class="text-lg font-extrabold text-neutral-900 group-hover:text-sky-700 transition-colors">@Product.Name</h2>
            </a>
        }
        else
        {
            <h2 class="text-lg font-extrabold text-neutral-900">@Product.Name</h2>
        }

        <p class="mt-2 text-sm text-neutral-600 leading-6">@Truncate(Product.Description)</p>

        @if (!string.IsNullOrWhiteSpace(Product.Slug))
        {
            <a href="@StorefrontRoutes.Product(Product.Slug)" aria-label="View @Product.Name" class="mt-5 block relative aspect-[4/3] overflow-hidden rounded-xl bg-neutral-50">
                <img src="@Product.Image" alt="@Product.Name" class="absolute inset-0 h-full w-full object-contain transition-transform duration-300 ease-out group-hover:scale-105" />
            </a>
        }
        else
        {
            <div class="mt-5 relative aspect-[4/3] overflow-hidden rounded-xl bg-neutral-50">
                <img src="@Product.Image" alt="@Product.Name" class="absolute inset-0 h-full w-full object-contain transition-transform duration-300 ease-out group-hover:scale-105" />
            </div>
        }
    </div>
    <div class="flex items-center justify-between gap-4 border-t border-neutral-100 px-6 py-4">
        <div>
            <div class="text-xs font-semibold uppercase tracking-[0.18em] text-neutral-500">Price</div>
            <div class="mt-1 text-xl font-extrabold text-neutral-900">€ @Product.Price</div>
        </div>
        @if (!string.IsNullOrWhiteSpace(Product.Slug))
        {
            <a href="@StorefrontRoutes.Product(Product.Slug)" class="inline-flex items-center rounded-md bg-neutral-900 text-white px-4 py-2 text-sm font-semibold hover:bg-neutral-800">
                View Product
            </a>
        }
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public GetCatalogProduct Product { get; set; } = new();

    private static string Truncate(string? value, int maxLength = 140)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= maxLength)
        {
            return value ?? string.Empty;
        }

        return $"{value[..maxLength].TrimEnd()}...";
    }
}