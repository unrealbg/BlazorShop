@page "/product/{Slug}"
@inject StorefrontApiClient ApiClient
@inject IStorefrontSeoComposer SeoComposer

<SeoHead Metadata="_metadata" />

@if (_isServiceUnavailable)
{
    <ServiceUnavailableState Title="Product temporarily unavailable"
                             Message="The storefront is running, but the catalog API is not reachable right now. Start the API project or AppHost and refresh this page." />
}
else if (_isNotFound)
{
    <NotFoundState Title="Product not found"
                   Message="We couldn't find a published product for this address." />
}
else if (_product is not null)
{
    <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid gap-8 lg:grid-cols-[1fr_1fr]">
            <div class="rounded-3xl bg-white/90 border border-neutral-200/70 shadow-lg p-6">
                <div class="relative aspect-[4/3] overflow-hidden rounded-2xl bg-neutral-50">
                    <img src="@_product.Image" alt="@_product.Name" class="absolute inset-0 h-full w-full object-contain" />
                </div>
            </div>

            <div class="rounded-3xl bg-white/90 border border-neutral-200/70 shadow-lg p-8">
                @if (!string.IsNullOrWhiteSpace(_product.Category?.Slug))
                {
                    <a href="@StorefrontRoutes.Category(_product.Category.Slug)" class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500 hover:text-neutral-900">@_product.Category.Name</a>
                }
                else if (!string.IsNullOrWhiteSpace(_product.Category?.Name))
                {
                    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">@_product.Category.Name</p>
                }

                <h1 class="mt-3 text-4xl font-extrabold tracking-tight">@_product.Name</h1>
                <div class="mt-5 text-3xl font-black text-neutral-900">€ @_product.Price</div>
                <p class="mt-6 text-base leading-7 text-neutral-700">@_product.Description</p>

                @if (_product.Variants.Any())
                {
                    <div class="mt-8">
                        <h2 class="text-sm font-semibold uppercase tracking-[0.2em] text-neutral-500">Available Variants</h2>
                        <ul class="mt-4 grid gap-3 sm:grid-cols-2">
                            @foreach (var variant in _product.Variants)
                            {
                                <li class="rounded-2xl border border-neutral-200 bg-neutral-50/80 px-4 py-3 text-sm text-neutral-700">
                                    <div class="font-semibold text-neutral-900">@variant.SizeValue</div>
                                    <div class="mt-1">@ScaleLabel(variant.SizeScale)</div>
                                    <div class="mt-2 font-semibold text-neutral-900">€ @(variant.Price ?? _product.Price)</div>
                                </li>
                            }
                        </ul>
                    </div>
                }

                <div class="mt-8 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-sm leading-6 text-amber-900">
                    Product discovery now lives on this route-based public page. Cart and checkout interactions remain in the legacy interactive client while the storefront transition continues.
                </div>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_product.SeoContent))
    {
        <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-16">
            <div class="rounded-3xl bg-white/90 border border-neutral-200/70 shadow-lg p-8">
                <h2 class="text-2xl font-extrabold tracking-tight">More about @_product.Name</h2>
                <div class="mt-4 whitespace-pre-line text-sm leading-7 text-neutral-700">@_product.SeoContent</div>
            </div>
        </section>
    }
}

@code {
    private SeoMetadataDto _metadata = new();
    private bool _isNotFound;
    private bool _isServiceUnavailable;
    private GetProduct? _product;

    [Parameter]
    public string Slug { get; set; } = string.Empty;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        var productResult = await ApiClient.GetPublishedProductBySlugAsync(Slug);

        if (productResult.IsServiceUnavailable)
        {
            _product = null;
            _isNotFound = false;
            _isServiceUnavailable = true;
            if (HttpContext is not null)
            {
                HttpContext.Response.StatusCode = StatusCodes.Status503ServiceUnavailable;
            }

            _metadata = await SeoComposer.ComposeServiceUnavailablePageAsync(
                "Product temporarily unavailable",
                StorefrontRoutes.Product(Slug),
                "The storefront is running, but the catalog API is not reachable right now.");
            return;
        }

        _product = productResult.Value;

        if (_product is null)
        {
            _isNotFound = true;
            _isServiceUnavailable = false;
            if (HttpContext is not null)
            {
                HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
            }

            _metadata = await SeoComposer.ComposeNotFoundPageAsync(
                "Product not found",
                StorefrontRoutes.Product(Slug),
                "We couldn't find a published product for this address.");
            return;
        }

        _isNotFound = false;
        _isServiceUnavailable = false;
        _metadata = await SeoComposer.ComposeProductPageAsync(_product);
    }

    private static string ScaleLabel(int scale)
    {
        return scale switch
        {
            1 => "Clothing",
            2 => "Clothing EU",
            10 => "Shoes EU",
            11 => "Shoes US",
            12 => "Shoes UK",
            _ => "Variant",
        };
    }
}