@page "/privacy"

<StaticPageSeo Title="Privacy Policy"
               RelativePath="@StorefrontRoutes.Privacy"
               Description="Review how BlazorShop handles customer information, browsing data, and storefront privacy expectations." />

<section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="rounded-3xl bg-white/90 border border-neutral-200/70 shadow-lg p-8 space-y-6 text-sm leading-7 text-neutral-700">
        <div>
            <h1 class="text-3xl font-extrabold tracking-tight text-neutral-900">Privacy Policy</h1>
            <p class="mt-3">BlazorShop respects customer privacy and limits public storefront pages to the information required for catalog discovery and support.</p>
        </div>
        <div>
            <h2 class="text-xl font-bold text-neutral-900">Information we collect</h2>
            <p class="mt-2">Account details, order information, newsletter subscriptions, and basic storefront usage data may be processed to deliver and improve the service.</p>
        </div>
        <div>
            <h2 class="text-xl font-bold text-neutral-900">How we use it</h2>
            <p class="mt-2">We use that information to provide catalog pages, process purchases, send operational emails, and improve the customer experience.</p>
        </div>
    </div>
</section>